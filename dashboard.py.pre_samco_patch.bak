    col1, col2, col3, col4 = st.columns(4)
    with col1:
        st.metric("BAC (Budget at Completion)", format_currency(kpis.get("bac", 0)))
    with col2:
        st.metric("AC (Actual Cost)", format_currency(kpis.get("ac", 0)))
    with col3:
        st.metric("EV (Earned Value)", format_currency(kpis.get("ev", 0)))
