        st.metric(
            "Schedule Performance Index",
            f"{spi:.2f}" if spi else "N/A",
            delta="On Track" if spi and spi >= 0.9 else "Behind",
        )
    with col4:
        cpi = kpis.get("cpi")
        st.metric(
            "Cost Performance Index",
            f"{cpi:.2f}" if cpi else "N/A",
