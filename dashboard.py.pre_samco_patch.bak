# TAB 8: S-CURVE ANALYSIS
# ═══════════════════════════════════════════════════════════════════════════════
with tab_s_curve:
    st.markdown("<div class='section-header'><h3>S-Curve Analysis - Financial Progress Tracking</h3></div>", unsafe_allow_html=True)
    
    st.markdown("""
    ### Overview
    The S-Curve is a cumulative cost curve that tracks planned vs actual project spending over time.
    It shows the project's financial progress and helps identify schedule and cost variances.
    """)
    
    st.divider()
    
    # Load S-Curve data
    s_curve_data = get_s_curve_data()
    s_curve_summary = get_s_curve_summary()
    
    # S-Curve Summary Metrics
    st.markdown("#### S-Curve Summary Metrics")
    
    col1, col2, col3, col4 = st.columns(4)
    
    with col1:
        st.metric(
            "Total Planned Budget",
            f"EGP {s_curve_summary['planned_total']:,.0f}",
            delta="Full Project"
        )
    
    with col2:
        st.metric(
            "Total Actual Spend",
            f"EGP {s_curve_summary['actual_total']:,.0f}",
            delta=f"{(s_curve_summary['actual_total']/s_curve_summary['planned_total']*100):.1f}% of Budget"
        )
    
    with col3:
        st.metric(
            "Total Invoiced",
            f"EGP {s_curve_summary['invoiced_total']:,.0f}",
            delta=f"{s_curve_summary['invoicing_to_actual_ratio']:.1f}% of Actual"
        )
    
    with col4:
        st.metric(
            "Last Actual Month",
            s_curve_summary['last_actual_month'],
            delta="Data Current"
        )
    
    st.divider()
    
    # S-Curve Chart
    st.markdown("#### Cumulative Spend Curve (Planned vs Actual vs Invoiced)")
    
    import pandas as pd
    
    # Create DataFrame for charting
    df_s_curve = pd.DataFrame({
        "Month": s_curve_data["months"],
        "Planned": s_curve_data["monthly_planned_cumm"],
        "Actual": s_curve_data["monthly_actual_cumm"],
        "Invoiced": s_curve_data["monthly_invoiced_cumm"]
    })
    
    # Create line chart
    fig = px.line(
        df_s_curve,
        x="Month",
        y=["Planned", "Actual", "Invoiced"],
        title="S-Curve: Cumulative Project Spend",
        labels={"value": "Cumulative Cost (EGP)", "variable": "Curve Type"},
        markers=True,
        color_discrete_map={
            "Planned": "#3b82f6",
            "Actual": "#10b981",
            "Invoiced": "#f59e0b"
        }
    )
    
    fig.update_layout(
        hovermode="x unified",
        height=500,
        xaxis_title="Month",
        yaxis_title="Cumulative Cost (EGP)"
    )
    
    st.plotly_chart(fig, use_container_width=True)
    
    st.divider()
    
    # Variance Analysis
    st.markdown("#### Variance Analysis")
    
    col1, col2 = st.columns(2)
    
    with col1:
        st.markdown("**Schedule Variance (SV)**")
        sv = s_curve_summary['schedule_variance']
        sv_pct = s_curve_summary['schedule_variance_pct']
        
        if sv >= 0:
            st.success(f"✅ Ahead of Schedule: EGP {sv:,.0f} ({sv_pct:.1f}%)")
        else:
            st.error(f"❌ Behind Schedule: EGP {sv:,.0f} ({sv_pct:.1f}%)")
        
        st.markdown("""
        **Interpretation:**
        - Positive SV: Actual spending is ahead of planned spending
        - Negative SV: Actual spending is behind planned spending
        - This indicates schedule performance (not cost performance)
        """)
    
    with col2:
        st.markdown("**Invoicing Performance**")
        invoicing_ratio = s_curve_summary['invoicing_to_actual_ratio']
        
        st.metric(
            "Invoiced to Actual Ratio",
            f"{invoicing_ratio:.1f}%",
            delta="Payment Collection"
        )
        
        st.markdown(f"""
        **Interpretation:**
        - Invoiced: EGP {s_curve_summary['invoiced_to_date']:,.0f}
        - Actual Spend: EGP {s_curve_summary['actual_to_date']:,.0f}
        - Outstanding: EGP {s_curve_summary['actual_to_date'] - s_curve_summary['invoiced_to_date']:,.0f}
        - Collection Rate: {invoicing_ratio:.1f}%
        """)
    
    st.divider()
    
    # Monthly Breakdown
    st.markdown("#### Monthly Breakdown")
    
    df_monthly = pd.DataFrame({
        "Month": s_curve_data["months"],
        "Planned": s_curve_data["monthly_planned"],
        "Actual": s_curve_data["monthly_actual"],
        "Invoiced": s_curve_data["monthly_invoiced"]
    })
    
    # Create grouped bar chart
    fig_monthly = px.bar(
        df_monthly,
        x="Month",
        y=["Planned", "Actual", "Invoiced"],
        title="Monthly Spend Comparison",
        labels={"value": "Monthly Cost (EGP)", "variable": "Type"},
        barmode="group",
        color_discrete_map={
            "Planned": "#3b82f6",
            "Actual": "#10b981",
            "Invoiced": "#f59e0b"
        }
    )
    
    fig_monthly.update_layout(height=400)
    st.plotly_chart(fig_monthly, use_container_width=True)
    
    st.divider()
    
    # Key Insights
    st.markdown("#### Key Insights & Analysis")
    
    col1, col2 = st.columns(2)
    
    with col1:
        st.markdown("**Project Status**")
        
        # Calculate progress
        actual_pct = (s_curve_summary['actual_total'] / s_curve_summary['planned_total'] * 100)
        invoiced_pct = (s_curve_summary['invoiced_total'] / s_curve_summary['planned_total'] * 100)
        
        st.markdown(f"""
        - **Actual Progress**: {actual_pct:.1f}% of total budget spent
        - **Invoicing Progress**: {invoiced_pct:.1f}% of total budget invoiced
        - **Outstanding Invoicing**: {100 - invoiced_pct:.1f}% pending
        - **Last Update**: {s_curve_summary['last_actual_month']}
        
        **Status**: Project is in active execution phase with regular monthly spending.
        """)
    
    with col2:
        st.markdown("**Financial Health**")
        
        # Calculate metrics
        monthly_avg_actual = s_curve_summary['actual_total'] / 7  # 7 months of data
        remaining_budget = s_curve_summary['planned_total'] - s_curve_summary['actual_total']
        months_remaining = 11  # Approximate
        
        st.markdown(f"""
        - **Average Monthly Spend**: EGP {monthly_avg_actual:,.0f}
        - **Remaining Budget**: EGP {remaining_budget:,.0f}
        - **Months Remaining**: ~{months_remaining}
        - **Projected Monthly Rate**: EGP {remaining_budget/months_remaining:,.0f}
        
        **Forecast**: Project is on track for budget completion by Mar-27.
        """)
    
    st.divider()
    
    # Detailed Data Table
    st.markdown("#### Detailed S-Curve Data")
    
    df_detailed = pd.DataFrame({
        "Month": s_curve_data["months"],
        "Monthly Planned": s_curve_data["monthly_planned"],
        "Cumulative Planned": s_curve_data["monthly_planned_cumm"],
        "Monthly Actual": s_curve_data["monthly_actual"],
        "Cumulative Actual": s_curve_data["monthly_actual_cumm"],
        "Monthly Invoiced": s_curve_data["monthly_invoiced"],
        "Cumulative Invoiced": s_curve_data["monthly_invoiced_cumm"]
    })
    
    st.dataframe(
        df_detailed,
        use_container_width=True,
        hide_index=True,
        column_config={
            "Monthly Planned": st.column_config.NumberColumn(format="EGP %.0f"),
            "Cumulative Planned": st.column_config.NumberColumn(format="EGP %.0f"),
            "Monthly Actual": st.column_config.NumberColumn(format="EGP %.0f"),
            "Cumulative Actual": st.column_config.NumberColumn(format="EGP %.0f"),
            "Monthly Invoiced": st.column_config.NumberColumn(format="EGP %.0f"),
            "Cumulative Invoiced": st.column_config.NumberColumn(format="EGP %.0f"),
        }
    )
    
    st.divider()
    
    # Recommendations
    st.markdown("#### Recommendations")
    
    st.info("""
    **1. Invoicing Acceleration**
    - Current invoicing is at 133.1% of actual spend (over-invoicing)
    - Continue aggressive invoicing strategy
    - Monitor payment collection closely
    
    **2. Schedule Monitoring**
    - Actual spending is ahead of planned schedule
    - Maintain current execution pace
    - Monitor for potential acceleration impacts
    
    **3. Budget Management**
    - Remaining budget: EGP 259.4M
    - Projected completion: Mar-27
    - Monitor monthly spend trends
    
    **4. Cash Flow**
    - Outstanding invoicing: EGP 0 (fully invoiced)
    - Focus on payment collection
    - Maintain invoicing momentum
    """)


