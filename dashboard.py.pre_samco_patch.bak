# TAB 7: TIME IMPACT ANALYSIS
# ═══════════════════════════════════════════════════════════════════════════════
with tab_time_impact:
    st.markdown("<div class='section-header'><h3>Time Impact Analysis - Delay Events</h3></div>", unsafe_allow_html=True)
    
    st.markdown("""
    ### Overview
    Time Impact Analysis evaluates how delay events affect project schedule and identifies critical path impacts.
    This analysis tracks material delivery delays and their cascading effects on dependent activities.
    """)
    
    st.divider()
    
    # Delay Event Summary
    st.markdown("#### Delay Event Summary")
    
    delay_events_data = {
        "Event ID": ["Event 1", "Event 2"],
        "Activity": ["CON-B01-BAS02-1010", "CON-B04-FOOT-1050"],
        "Activity Name": [
            "RFT for Walls, Col. & Cores (B01) (Bas 02)",
            "RFT for RC Raft & Footings (B04)"
        ],
        "Original Duration (days)": [15, 8],
        "Planned Start": ["25-Dec-25", "22-Mar-26"],
        "Planned Finish": ["12-Jan-26", "30-Mar-26"],
        "Delay Days": [46, 45],
        "Root Cause": [
            "Material Delivery Delay",
            "Material Delivery Delay"
        ],
        "Activity % Complete": ["41%", "28%"],
        "Impact Type": ["Critical Path", "Critical Path"]
    }
    
    df_delay_events = pd.DataFrame(delay_events_data)
    st.dataframe(df_delay_events, use_container_width=True, hide_index=True)
    
    st.divider()
    
    # Time Impact Metrics
    st.markdown("#### Time Impact Metrics")
    
    col1, col2, col3, col4 = st.columns(4)
    
    with col1:
        st.metric("Total Delay Events", 2)
    with col2:
        st.metric("Total Delay Days", 91)
    with col3:
        st.metric("Critical Path Impact", "2 Activities")
    with col4:
        st.metric("Average Delay", "45.5 days")
    
    st.divider()
    
    # Delay Impact Analysis
    st.markdown("#### Detailed Delay Impact Analysis")
    
    col1, col2 = st.columns(2)
    
    with col1:
        st.markdown("**Event 1: Material Delivery Delay (B01)**")
        st.markdown("""
        - **Activity**: RFT for Walls, Col. & Cores (B01) (Bas 02)
        - **Activity ID**: CON-B01-BAS02-1010
        - **Original Duration**: 15 days
        - **Planned Period**: 25-Dec-25 to 12-Jan-26
        - **Delay Days**: 46 days
        - **Material Delivery**: 13-Feb-26 (partial - 371 tons out of 726 tons)
        - **Activity Progress**: 41% complete
        - **Fragment Strategy**: 
          - Part 1: 6 days (25-Dec-25 to 31-Dec-25)
          - Part 2: Remaining (16-Feb-26 to 25-Feb-26)
        - **Root Cause**: Delay on Employee free-issue materials
        - **Impact**: Cascading delay to dependent activities
        """)
    
    with col2:
        st.markdown("**Event 2: Material Delivery Delay (B04)**")
        st.markdown("""
        - **Activity**: RFT for RC Raft & Footings (B04)
        - **Activity ID**: CON-B04-FOOT-1050
        - **Original Duration**: 8 days
        - **Planned Period**: 22-Mar-26 to 30-Mar-26
        - **Delay Days**: 45 days
        - **Material Delivery**: 05-May-26
        - **Activity Progress**: 28% complete
        - **Fragment Strategy**:
          - Part 1: 2 days (24-Mar-26)
          - Part 2: Remaining (08-May-26 to 14-May-26)
        - **Root Cause**: Delay on Employee free-issue materials
        - **Impact**: Pushes subsequent activities (B04-FOOT-1070, B04-BAS02-1010)
        """)
    
    st.divider()
    
    # Schedule Impact Chart
    st.markdown("#### Schedule Impact Visualization")
    
    schedule_data = {
        "Activity": ["B01-BAS02-1010", "B04-FOOT-1050"],
        "Original Duration": [15, 8],
        "Delay Impact": [46, 45],
        "Total Duration": [61, 53]
    }
    
    df_schedule = pd.DataFrame(schedule_data)
    
    fig = px.bar(
        df_schedule,
        x="Activity",
        y=["Original Duration", "Delay Impact"],
        title="Schedule Impact: Original vs Delay",
        labels={"value": "Days", "variable": "Duration Type"},
        barmode="stack",
        color_discrete_map={"Original Duration": "#3b82f6", "Delay Impact": "#ef4444"}
    )
    st.plotly_chart(fig, use_container_width=True)
    
    st.divider()
    
    # Critical Path Analysis
    st.markdown("#### Critical Path Analysis")
    
    critical_path_data = {
        "Activity Sequence": [
            "B01-FOOT-1050 → B01-FOOT-1070 → B01-BAS02-1010",
            "B04-FOOT-1050 → B04-FOOT-1070 → B04-BAS02-1010"
        ],
        "Original Duration": ["30 days", "23 days"],
        "With Delay": ["76 days", "68 days"],
        "Schedule Slip": ["46 days", "45 days"],
        "Status": ["Critical", "Critical"]
    }
    
    df_critical = pd.DataFrame(critical_path_data)
    st.dataframe(df_critical, use_container_width=True, hide_index=True)
    
    st.divider()
    
    # Mitigation Strategies
    st.markdown("#### Mitigation Strategies Applied")
    
    col1, col2 = st.columns(2)
    
    with col1:
        st.markdown("**Activity Fragmentation**")
        st.markdown("""
        ✓ Split activities into multiple parts
        ✓ Execute Part 1 with available resources
        ✓ Resume Part 2 after material delivery
        ✓ Reduces idle time and maintains crew productivity
        """)
    
    with col2:
        st.markdown("**Resource Optimization**")
        st.markdown("""
        ✓ Reallocate crews to non-impacted activities
        ✓ Accelerate parallel activities (B02, B03)
        ✓ Prepare for material receipt (staging, inspection)
        ✓ Maintain schedule buffer for other activities
        """)
    
    st.divider()
    
    # Key Metrics
    st.markdown("#### Key Performance Indicators")
    
    col1, col2, col3, col4 = st.columns(4)
    
    with col1:
        st.metric(
            "Schedule Variance (Days)",
            "-91",
            delta="Behind Schedule",
            delta_color="inverse"
        )
    
    with col2:
        st.metric(
            "Critical Activities Impacted",
            "2",
            delta="On Critical Path",
            delta_color="inverse"
        )
    
    with col3:
        st.metric(
            "Average Delay Impact",
            "45.5 days",
            delta="Per Activity",
            delta_color="inverse"
        )
    
    with col4:
        st.metric(
            "Material Delivery Reliability",
            "50%",
            delta="Partial Delivery",
            delta_color="inverse"
        )
    
    st.divider()
    
    # Recommendations
    st.markdown("#### Recommendations")
    
    st.info("""
    **1. Material Supply Chain Management**
    - Establish backup suppliers for critical materials
    - Implement early warning system for delivery delays
    - Increase safety stock for high-impact materials
    
    **2. Schedule Optimization**
    - Compress non-critical path activities
    - Implement concurrent execution where possible
    - Maintain activity buffers for risk mitigation
    
    **3. Stakeholder Communication**
    - Weekly delay impact reports
    - Escalation protocol for critical delays
    - Contingency plan activation triggers
    
    **4. Resource Planning**
    - Cross-train crews for activity flexibility
    - Maintain resource buffer for acceleration
    - Plan for extended project duration
    """)


