        st.metric("CPI (Cost Performance Index)", f"{cpi:.3f}" if cpi else "N/A", delta=status)
    with col3:
        st.metric("SV (Schedule Variance)", format_currency(kpis.get("sv", 0)))
    with col4:
        st.metric("CV (Cost Variance)", format_currency(kpis.get("cv", 0)))

    st.divider()

