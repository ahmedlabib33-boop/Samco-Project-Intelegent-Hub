# TAB 9: CONTRACT CLAUSE MATCHING ENGINE
# ═══════════════════════════════════════════════════════════════════════════════
with tab_clause_matcher:
    st.markdown("<div class='section-header'><h3>Contract Clause Matching Engine</h3></div>", unsafe_allow_html=True)
    
    st.markdown("""
    ### Overview
    This tool matches project events to applicable contract clauses and provides:
    - Entitlement analysis
    - Notice requirements
    - Financial and schedule impacts
    - Critical actions and evidence requirements
    """)
    
    st.divider()
    
    # Event Matching Section
    st.markdown("#### Event-to-Clause Matching")
    
    col1, col2 = st.columns(2)
    
    with col1:
        event_type = st.selectbox(
            "Select Event Type",
            [
                "Material Delivery Delay",
                "Variation / Change Order",
                "Payment Delay",
                "Remeasurement",
                "Other"
            ]
        )
    
    with col2:
        event_description = st.text_input(
            "Event Description",
            placeholder="e.g., Steel delivery delayed by 46 days"
        )
    
    if st.button("🔍 Find Applicable Clauses"):
        if event_description:
            applicable_clauses = match_event_to_clauses(event_type, event_description)
            
            if applicable_clauses:
                st.success(f"Found {len(applicable_clauses)} applicable clauses")
                
                for i, match in enumerate(applicable_clauses, 1):
                    with st.expander(f"**{i}. {match['clause'].topic}** (Clause {match['clause'].clause_id}) - {match['relevance']}"):
                        col1, col2 = st.columns(2)
                        
                        with col1:
                            st.markdown("**Plain English:**")
                            st.write(match['clause'].plain_english)
                            
                            st.markdown("**Beneath the Lines:**")
                            st.write(match['clause'].beneath_lines)
                        
                        with col2:
                            st.markdown("**Leverage Holder:**")
                            st.write(match['clause'].leverage_holder)
                            
                            st.markdown("**Notice Requirement:**")
                            st.write(match['clause'].notice_requirement)
                        
                        st.divider()
                        
                        st.markdown("**Analysis:**")
                        st.write(f"**Reason:** {match['reason']}")
                        st.write(f"**Action Required:** {match['action_required']}")
                        st.write(f"**Entitlement Risk:** {match['entitlement_risk']}")
                        st.write(f"**Time Impact:** {match['time_impact']}")
                        st.write(f"**Cost Impact:** {match['cost_impact']}")
                        
                        st.markdown("**Practical Action:**")
                        st.write(match['clause'].practical_action)
            else:
                st.warning("No applicable clauses found for this event type.")
        else:
            st.warning("Please enter an event description.")
    
    st.divider()
    
    # Delay Event Analysis
    st.markdown("#### Delay Event Analysis")
    
    col1, col2, col3 = st.columns(3)
    
    with col1:
        delay_days = st.number_input("Delay Days", min_value=1, value=46)
    
    with col2:
        is_contractor_caused = st.checkbox("Contractor-Caused?", value=False)
    
    with col3:
        is_critical_path = st.checkbox("Critical Path?", value=True)
    
    if st.button("📊 Analyze Delay Event"):
        analysis = analyze_delay_event(
            event_id="DEL-001",
            event_name="Material Delivery Delay",
            delay_days=delay_days,
            is_contractor_caused=is_contractor_caused,
            is_critical_path=is_critical_path
        )
        
        # Display analysis results
        col1, col2, col3, col4 = st.columns(4)
        
        with col1:
            st.metric("Delay Days", analysis['delay_days'])
        
        with col2:
            st.metric("Entitlement", analysis['entitlement'])
        
        with col3:
            st.metric(
                "Delay Damages/Week",
                f"EGP {analysis['delay_damages_per_week']:,.0f}",
                delta="Per week"
            )
        
        with col4:
            st.metric(
                "Total Exposure",
                f"EGP {analysis['delay_damages_exposure']:,.0f}",
                delta="Capped at 10%"
            )
        
        st.divider()
        
        st.markdown("**Critical Actions Required:**")
        for i, action in enumerate(analysis['critical_actions'], 1):
            st.write(f"{i}. {action}")
        
        st.divider()
        
        st.markdown("**Applicable Clauses:**")
        for match in analysis['applicable_clauses']:
            with st.expander(f"{match['clause'].topic} (Clause {match['clause'].clause_id})"):
                st.write(f"**Relevance:** {match['relevance']}")
                st.write(f"**Reason:** {match['reason']}")
                st.write(f"**Action:** {match['action_required']}")
    
    st.divider()
    
    # Clause Library Browser
    st.markdown("#### Contract Clause Library")
    
    search_term = st.text_input(
        "🔍 Search Clauses",
        placeholder="e.g., 'delay', 'payment', 'variation'"
    )
    
    if search_term:
        search_results = search_clauses(search_term)
        st.info(f"Found {len(search_results)} clauses matching '{search_term}'")
        
        for clause in search_results:
            with st.expander(f"**{clause.topic}** (Clause {clause.clause_id})"):
                col1, col2 = st.columns(2)
                
                with col1:
                    st.markdown("**Location:**")
                    st.write(clause.location)
                    
                    st.markdown("**Plain English:**")
                    st.write(clause.plain_english)
                    
                    st.markdown("**Beneath the Lines:**")
                    st.write(clause.beneath_lines)
                
                with col2:
                    st.markdown("**Leverage Holder:**")
                    st.write(clause.leverage_holder)
                    
                    st.markdown("**Notice Requirement:**")
                    st.write(clause.notice_requirement)
                    
                    st.markdown("**Money Impact:**")
                    st.write(clause.money_impact)
                    
                    st.markdown("**Schedule Impact:**")
                    st.write(clause.schedule_impact)
                
                st.divider()
                
                st.markdown("**Practical Action:**")
                st.write(clause.practical_action)
    else:
        st.info("Enter a search term to find relevant clauses")
    
    st.divider()
    
    # All Clauses Summary Table
    st.markdown("#### All Contract Clauses Summary")
    
    all_clauses = get_all_clauses()
    
    clause_data = {
        "Clause ID": [c.clause_id for c in all_clauses],
        "Topic": [c.topic for c in all_clauses],
        "Location": [c.location for c in all_clauses],
        "Leverage": [c.leverage_holder for c in all_clauses],
        "Money Impact": [c.money_impact[:50] + "..." if len(c.money_impact) > 50 else c.money_impact for c in all_clauses],
        "Schedule Impact": [c.schedule_impact[:50] + "..." if len(c.schedule_impact) > 50 else c.schedule_impact for c in all_clauses]
    }
    
    df_clauses = pd.DataFrame(clause_data)
    st.dataframe(df_clauses, use_container_width=True, hide_index=True)
    
    st.divider()
    
    # Key Takeaways
    st.markdown("#### Key Takeaways")
    
    col1, col2, col3 = st.columns(3)
    
    with col1:
        st.markdown("**⚠️ Critical Clauses**")
        st.markdown("""
        - Clause 20.1: Claims Time Bar
        - Clause 8.7: Delay Damages
        - Clause 13.3: Variation Procedure
        
        *Missed procedures = waived claims*
        """)
    
    with col2:
        st.markdown("**💰 Financial Exposure**")
        st.markdown("""
        - Delay Damages: 1% per week
        - Cap: 10% of contract value
        - Contract Value: EGP 367.3M
        - Max Exposure: EGP 36.7M
        """)
    
    with col3:
        st.markdown("**📋 Required Evidence**")
        st.markdown("""
        - Approved programme
        - Requisitions & delivery notes
        - Monthly claim accounts
        - Critical path analysis
        - Timely notices
        """)


