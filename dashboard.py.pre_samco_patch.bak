        st.metric("PV (Planned Value)", format_currency(kpis.get("pv", 0)))

    st.divider()

    col1, col2, col3, col4 = st.columns(4)
    with col1:
        spi = kpis.get("spi")
        status = "✅ On Track" if spi and spi >= 0.95 else ("⚠️ At Risk" if spi and spi >= 0.85 else "❌ Behind")
        st.metric("SPI (Schedule Performance Index)", f"{spi:.3f}" if spi else "N/A", delta=status)
    with col2:
        cpi = kpis.get("cpi")
