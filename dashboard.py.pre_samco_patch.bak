            fig = px.pie(values=severity_counts.values, names=severity_counts.index, title="Risk Severity")
            st.plotly_chart(fig, use_container_width=True)

        with col2:
            st.subheader("Risk Category Distribution")
            category_counts = df_risks["category"].value_counts()
            df_category = pd.DataFrame({"Category": category_counts.index, "Count": category_counts.values})
            fig = px.bar(df_category, x="Category", y="Count", title="Risk Category", color_discrete_sequence=["#8b5cf6"])
            st.plotly_chart(fig, use_container_width=True)

        st.divider()

        # Risk Details Table
        st.subheader("Risk Register")
        st.dataframe(
            df_risks[[
                "risk_code", "risk_title", "category", "probability",
                "time_impact_days", "cost_impact", "severity_band",
                "response_strategy", "mitigation_status"
            ]],
            use_container_width=True,
            hide_index=True,
        )
