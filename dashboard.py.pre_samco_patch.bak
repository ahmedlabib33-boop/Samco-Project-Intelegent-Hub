# ── Helper Functions ──────────────────────────────────────────────────────────
def get_status_color(value, threshold_good=0.9, threshold_warning=0.8):
    """Return status color based on value (SPI/CPI)."""
    if value is None:
        return "gray"
    if value >= threshold_good:
        return "green"
    elif value >= threshold_warning:
        return "orange"
    else:
        return "red"


def format_currency(value):
    """Format value as currency."""
    if value is None:
        return "$0"
    return f"${value:,.0f}"


def format_percentage(value):
    """Format value as percentage."""
    if value is None:
        return "0%"
    return f"{value:.1f}%"


